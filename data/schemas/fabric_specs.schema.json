{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "source_ids", "is_mock", "materials", "structures", "finishes", "processes", "compatibility_rules"],
  "properties": {
    "schema_version": {"type": "string"},
    "source_ids": {"type": "array", "items": {"type": "string"}},
    "is_mock": {"const": true},
    "materials": {"type": "array", "minItems": 1},
    "structures": {"type": "array", "minItems": 1},
    "finishes": {"type": "array", "minItems": 1},
    "processes": {"type": "array", "minItems": 1},
    "compatibility_rules": {"type": "array", "minItems": 1}
  },
  "additionalProperties": false
}
