{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "source_ids", "is_mock", "currency", "unit", "effective_from", "materials", "yarn_processing", "manufacturing", "dyeing", "finishing", "quality", "waste_rate"],
  "properties": {
    "schema_version": {"type": "string"},
    "source_ids": {"type": "array", "items": {"type": "string"}},
    "is_mock": {"const": true},
    "currency": {"const": "CNY"},
    "unit": {"const": "meter"},
    "effective_from": {"type": "string"},
    "materials": {"type": "array", "minItems": 1},
    "yarn_processing": {"type": "array", "minItems": 1},
    "manufacturing": {"type": "array", "minItems": 1},
    "dyeing": {"type": "array", "minItems": 1},
    "finishing": {"type": "array", "minItems": 1},
    "quality": {"type": "object"},
    "waste_rate": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "additionalProperties": false
}
